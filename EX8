#include<stdio.h>
#include<stdlib.h>
#include<omp.h>
int main()
{
   printf("Running Minimum:\n");
   int size;
   int *arr;int *arr1;
   printf("Enter the size:");
   scanf("%d",&size);
   arr=(int*)malloc(size*sizeof(int));
   arr1=(int*)malloc(size*sizeof(int));
   printf("Enter the array:\n");
   for(int i=0;i<size;i++)
       scanf("%d",&arr[i]);
   int min=arr[0];
   arr1[0]=min;
 #pragma omp parallel for
   for(int i=0;i<size;i++)
   {
      if(arr[i]<min)
      {
	 arr1[i]=arr[i];
      }
      else
         arr1[i]=min;
   }
   printf("The running minimum(s):");
   for(int i=0;i<size;i++)
      printf("%d ",arr1[i]);
   printf("\n");
   return 0;
}
