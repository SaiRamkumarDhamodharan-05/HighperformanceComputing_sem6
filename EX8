#include<stdio.h>
#include<stdlib.h>
#include<omp.h>
int main()
{
   printf("Mirror Matrix printing\n");
   int dim;
   int **A;
   printf("Enter matrix dimension:");
   scanf("%d",&dim);
   A=(int**)malloc(dim*sizeof(int*));
   for(int i=0;i<dim;i++)
      A[i]=(int*)malloc(dim*sizeof(int));
   printf("Enter the matrix:\n");
   for(int i=0;i<dim;i++)
   {
      for(int j=0;j<dim;j++)
      {
	 scanf("%d",&A[i][j]);
      }
   }
   int **B;
   B=(int**)malloc(dim*sizeof(int*));
   for(int i=0;i<dim;i++)
      B[i]=(int*)malloc(dim*sizeof(int));
 #pragma omp parallel for collapse(2)
   for(int i=0;i<dim;i++)
   {
      for(int j=0;j<dim;j++)
      {
	 B[i][dim-j-1]=A[i][j];
      }
   }
   printf("The Mirror matrix is:\n");
   for(int i=0;i<dim;i++)
   {
      for(int j=0;j<dim;j++)
      {
         printf("%d ",B[i][j]);
      }
   printf("\n");
   }
   return 0;
}
