#include <stdio.h>
#include <stdlib.h>
#include <pthread.h>

#define MAX 100

int arr[MAX];
int n;
int partial_sum[MAX] = {0};
int thread_count;

void* sumArray(void* arg) {

    int id = *(int*)arg;   // get thread id
    int part = n / thread_count;

    int start = id * part;
    int end;

    if(id == thread_count-1)
        end = n;     
    else
        end = (id + 1) * part;
    for(int i = start; i < end; i++) {
        partial_sum[id] += arr[i];
    }
    printf("\nSum by thread %d: %d\n",id,partial_sum[id]);
    pthread_exit(NULL);
}

int main(int argc,char *argv[]) {
    
    thread_count=strtol(argv[1],NULL,10);    
    pthread_t threads[thread_count];
    int thread_id[thread_count];

    printf("Enter number of elements: ");
    scanf("%d", &n);

    srand(time(NULL));
    for(int i = 0; i < n; i++) {
        arr[i]=rand()%100;
    }
    for(int i=0;i<n;i++) printf("%d ",arr[i]);

    for(int i = 0; i < thread_count; i++) {
        thread_id[i] = i;
        pthread_create(&threads[i], NULL, sumArray, &thread_id[i]);
    }

    // Wait for threads
    for(int i = 0; i < thread_count; i++) {
        pthread_join(threads[i], NULL);
    }

    int total = 0;
    for(int i = 0; i < thread_count; i++) {
        total += partial_sum[i];
    }

    printf("\nFinal Sum = %d\n", total);

    return 0;
}
