#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <pthread.h>

#define BUFFER_SIZE 10
#define WORD_LEN 50
#define THREADS 3

char *dictionary[] = {"apple","banana","orange","grape","mango","computer","science","hello","world"};
int dict_size = 9;

char buffer[BUFFER_SIZE][WORD_LEN];
int count = 0;
int done = 0;  // flag to indicate no more words will be added

pthread_mutex_t lock;
pthread_cond_t not_empty;
pthread_cond_t not_full;

int spell_check(char *word)
{
    for(int i = 0; i < dict_size; i++)
    {
        if(strcmp(dictionary[i], word) == 0)
            return 1;  // word is in dictionary
    }
    return 0;  // word not found
}

void* spell_checker(void *arg)
{
    char word[WORD_LEN];
    while(1)
    {
        pthread_mutex_lock(&lock);
        while(count == 0 && !done)
            pthread_cond_wait(&not_empty, &lock);

        if(count == 0 && done) {
            pthread_mutex_unlock(&lock);
            break;
        }

        strcpy(word, buffer[count - 1]);
        count--;
        pthread_cond_signal(&not_full);
        pthread_mutex_unlock(&lock);

        int correct = spell_check(word);

        pthread_mutex_lock(&lock);
        if(correct)
            printf("%s -> Correct\n", word);
        else
            printf("%s -> Incorrect\n", word);
        pthread_mutex_unlock(&lock);
    }
    return NULL;
}

int main()
{
    pthread_t workers[THREADS];
    pthread_mutex_init(&lock, NULL);
    pthread_cond_init(&not_empty, NULL);
    pthread_cond_init(&not_full, NULL);

    printf("*** Spell Checker Using Pthread Synchronization *** - CASE SENSITIVE\n");

    // Print available dictionary
    printf("Dictionary available:\n");
    for(int i = 0; i < dict_size; i++)
        printf(" - %s\n", dictionary[i]);
    printf("\n");

    int n;
    printf("Enter number of words to check: ");
    scanf("%d", &n);

    for(int i = 0; i < THREADS; i++)
        pthread_create(&workers[i], NULL, spell_checker, NULL);

    printf("Enter words one by one:\n");
    for(int i = 0; i < n; i++)
    {
        char word[WORD_LEN];
        scanf("%s", word);

        pthread_mutex_lock(&lock);
        while(count == BUFFER_SIZE)
            pthread_cond_wait(&not_full, &lock);
        strcpy(buffer[count++], word);
        pthread_cond_signal(&not_empty);
        pthread_mutex_unlock(&lock);
    }

    // Notify workers no more words will be added
    pthread_mutex_lock(&lock);
    done = 1;
    pthread_cond_broadcast(&not_empty);
    pthread_mutex_unlock(&lock);

    for(int i = 0; i < THREADS; i++)
        pthread_join(workers[i], NULL);

    pthread_mutex_destroy(&lock);
    pthread_cond_destroy(&not_empty);
    pthread_cond_destroy(&not_full);

    return 0;
}
