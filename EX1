#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <sys/ipc.h>
#include <sys/shm.h>
#include <sys/wait.h>
#include <time.h>
int main(void) {
    int n,i,j,k;
    printf("Matrix Multiplication\n");
    printf("Enter the dimension: ");
    scanf("%d", &n);
    size_t size = n * n * n * sizeof(int);
    int shmid = shmget(IPC_PRIVATE, size, IPC_CREAT | 0666);
    if (shmid < 0) {
        perror("shmget (mats)");
        return 1;
    }
    void *mat = (int*)shmat(shmid, NULL, 0);
    if (mat == (void *)-1) {
        perror("shmat (mats)");
        return 1;
    }
    int *A = mat;
    int *B = A + n * n;
    int *C = B + n * n;
    size_t time_s = n * sizeof(double);
    int shmid_t = shmget(IPC_PRIVATE, time_s, IPC_CREAT | 0666);
    double *times = (double *)shmat(shmid_t, NULL, 0);
    for (i = 0; i < n; i++) {
        for (j = 0; j < n; j++) {
            A[i * n + j] = rand() % 100;
            B[i * n + j] = rand() % 100;
        }
    }
    for (i = 0; i < n; i++) {
        pid_t pid = fork();
        if (pid == 0) {
            struct timespec start, end;
            clock_gettime(CLOCK_MONOTONIC, &start);
            for (j = 0; j < n; j++) {
                int sum = 0;
                for (k = 0; k < n; k++) {
                    sum += A[i * n + k] * B[k * n + j];
                }
                C[i * n + j] = sum;
            }
            clock_gettime(CLOCK_MONOTONIC, &end);
            double ptime_r = (end.tv_sec - start.tv_sec) +
                             (end.tv_nsec - start.tv_nsec) / 1e9;
            times[i] = ptime_r;
            exit(0);
        }
    }
    for (i = 0; i < n; i++) {
        wait(NULL);
    }
    double max_time = 0.0;
    int max_row = -1;
    for (i = 0; i < n; i++) {
        if (times[i] > max_time) {
            max_time = times[i];
        }
    }
    if(n<=5)
        {
           printf("Matrix A:\n");
           for (i = 0; i < n; i++){
             for (j = 0; j < n; j++){
                 printf("%d ",A[i*n+j]);
             }
             printf("\n");
           }
           printf("Matrix B:\n");
           for (i = 0; i < n; i++){
              for (j = 0; j < n; j++){
                 printf("%d ",B[i*n+j]);
             }
              printf("\n");
           }
           printf("Result:\n");
         for (i = 0; i < n; i++){
           for (j = 0; j < n; j++){
                 printf("%d ",C[i*n+j]);
           }
           printf("\n");
         }
        }
    printf("Parallel Execution time : %.6f seconds\n", max_time);
    return 0;
}
