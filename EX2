#include <unistd.h>
#include <sys/ipc.h>
#include <sys/shm.h>
#include <sys/wait.h>
#include <time.h>
int main() {
    int i, j, k, n;
    printf("Matrix Operations using TASK PARALLELISM\n");
    int **A,**B,**C;
    printf("Enter the dimension of the matrix:");
    scanf("%d", &n);
    A=(int**)malloc(n*sizeof(int*));
    for(i=0;i<n;i++)
    {
       A[i]=(int*)malloc(n*sizeof(int));
    }
    B=(int**)malloc(n*sizeof(int*));
    for(i=0;i<n;i++)
    {
       B[i]=(int*)malloc(n*sizeof(int));
    }
    C=(int**)malloc(n*sizeof(int*));
    for(i=0;i<n;i++)
    {
       C[i]=(int*)malloc(n*sizeof(int));
    }
    for (i = 0; i < n; i++){
        for (j = 0; j < n; j++){
            A[i][j]=rand()%100;
        }
    }
    for (i = 0; i < n; i++){
        for (j = 0; j < n; j++){
            B[i][j]=rand()%100;
        }
    } 
    int shmid = shmget(IPC_PRIVATE, 4 * sizeof(double), IPC_CREAT | 0666);
    if (shmid < 0) {
        perror("shmget time");
        exit(1);
    }
    double *time = (double *)shmat(shmid, NULL, 0);
    if (fork() == 0) {
        struct timespec s, e;
        clock_gettime(CLOCK_MONOTONIC, &s);
        for (i = 0; i < n; i++){
            for (j = 0; j < n; j++){
                C[i][j] = A[i][j] + B[i][j];
            }
        }
        clock_gettime(CLOCK_MONOTONIC, &e);
        time[0] = (e.tv_sec - s.tv_sec) + (e.tv_nsec - s.tv_nsec) / 1e9;
        exit(0);
    }
    if (fork() == 0) {
        struct timespec s, e;
        clock_gettime(CLOCK_MONOTONIC, &s);
        for (i = 0; i < n; i++){
            for (j = 0; j < n; j++){
                C[i][j] = A[i][j] - B[i][j];
             }
         }
        clock_gettime(CLOCK_MONOTONIC, &e);
        time[1] = (e.tv_sec - s.tv_sec) + (e.tv_nsec - s.tv_nsec) / 1e9;
        exit(0);
    }
    if (fork() == 0) {
        struct timespec s, e;
        clock_gettime(CLOCK_MONOTONIC, &s);
        for (i = 0; i < n; i++) {
            for (j = 0; j < n; j++) {
                int sum = 0;
                for (k = 0; k < n; k++)
                    sum += A[i][k] * B[k][j];
                C[i][j] = sum;
            }
        }
        clock_gettime(CLOCK_MONOTONIC, &e);
        time[2] = (e.tv_sec - s.tv_sec) + (e.tv_nsec - s.tv_nsec) / 1e9;
        exit(0);
    }
    if (fork() == 0) {
        struct timespec s, e;
        clock_gettime(CLOCK_MONOTONIC, &s);
        for (i = 0; i < n; i++){
            for (j = 0; j < n; j++){
                C[i][j] = A[j][i];
            }
        }
        clock_gettime(CLOCK_MONOTONIC, &e);
        time[3] = (e.tv_sec - s.tv_sec) + (e.tv_nsec - s.tv_nsec) / 1e9;
        exit(0);
    }
    for (i = 0; i < 4; i++)
        wait(NULL);
    double max_time = -1;
    for (i = 0; i < 4; i++) {
        if (time[i] > max_time)
            max_time = time[i];
    }
