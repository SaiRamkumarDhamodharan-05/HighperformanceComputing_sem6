#include <stdio.h>
#include <stdlib.h>
#include <pthread.h>
#include <semaphore.h>
#include <time.h>
int num1, num2;
char op;
sem_t job_ready;
sem_t job_done;

FILE *fp;
void *server(void *arg)
{
    char ops[] = {'+','-','*','/'};
    srand(time(NULL));
    for(int i = 0; i < 20; i++)
    {
        num1 = rand()%50 + 1;
        num2 = rand()%50 + 1;
        op = ops[rand()%4];
        printf("Generated: %d %c %d\n", num1, op, num2);
        sem_post(&job_ready);   
        sem_wait(&job_done);  
    }

    pthread_exit(NULL);
}
void *add_thread(void *arg)
{
    pthread_t id=pthread_self();
    while(1)
    {
        sem_wait(&job_ready);

        if(op == '+')
        {
            int res = num1 + num2;
            fprintf(fp,"thread %d : %d + %d = %d\n",id,num1,num2,res);
            fflush(fp);
            sem_post(&job_done);
        }
        else
        {
            sem_post(&job_ready);
        }
    }
}
void *sub_thread(void *arg)
{
    pthread_t id=pthread_self();
    while(1)
    {
        sem_wait(&job_ready);

        if(op == '-')
        {
            int res = num1 - num2;
            fprintf(fp,"thread %d : %d - %d = %d\n",id,num1,num2,res);
            fflush(fp);

            sem_post(&job_done);
        }
        else
        {
            sem_post(&job_ready);
        }
    }
}
void *mul_thread(void *arg)
{
    pthread_t id=pthread_self();
    while(1)
    {
        sem_wait(&job_ready);

        if(op == '*')
        {
            int res = num1 * num2;
            fprintf(fp,"thread %d : %d * %d = %d\n",id,num1,num2,res);
            fflush(fp);

            sem_post(&job_done);
        }
        else
        {
            sem_post(&job_ready);
        }
    }
}
void *div_thread(void *arg)
{
    pthread_t id=pthread_self();
    while(1)
    {
        sem_wait(&job_ready);

        if(op == '/')
        {
            if(num2 != 0)
            {
                float res = (float)num1 / num2;
                fprintf(fp,"thread %d : %d / %d = %.2f\n",id,num1,num2,res);
                fflush(fp);
            }

            sem_post(&job_done);
        }
        else
        {
            sem_post(&job_ready);
        }
    }
}
int main()
{
    pthread_t server_t, t1, t2, t3, t4;
    srand(time(NULL));
    fp = fopen("result.txt","w");
    sem_init(&job_ready,0,0);
    sem_init(&job_done,0,0);
    pthread_create(&server_t,NULL,server,NULL);
    pthread_create(&t1,NULL,add_thread,NULL);
    pthread_create(&t2,NULL,sub_thread,NULL);
    pthread_create(&t3,NULL,mul_thread,NULL);
    pthread_create(&t4,NULL,div_thread,NULL);
    pthread_join(server_t,NULL);
    return 0;
}


