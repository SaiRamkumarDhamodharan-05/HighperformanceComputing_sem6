#include <stdio.h>
#include <omp.h>
#include <math.h>
double f(double x) {
    return x * x;
}

int main() {
    int n, i;
    double a, b, h, sum = 0.0;
    printf("TRAPEZOIDAL SUM\n");
    printf("Enter lower limit a: ");
    scanf("%lf", &a);
    printf("Enter upper limit b: ");
    scanf("%lf", &b);
    printf("Enter number of intervals n: ");
    scanf("%d", &n);
    h = (b - a) / n;
    #pragma omp parallel for reduction(+:sum)
    for (i = 1; i < n; i++) {
        sum += f(a + i * h);
    }
    double result = h * ((f(a) + f(b)) / 2.0 + sum);
    printf("Trapezoidal Sum = %lf\n", result);
    return 0;
}
