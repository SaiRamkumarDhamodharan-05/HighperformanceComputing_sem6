#include<stdio.h>
#include<stdlib.h>
#include<omp.h>

int main()
{
   int n, count = 0;
   int **mat;
   printf("COUNT OF SADDLE POINTS\n");
   printf("Enter dimension of the matrix: ");
   scanf("%d", &n);

   mat = (int**)malloc(n * sizeof(int*));
   for(int i = 0; i < n; i++)
      mat[i] = (int*)malloc(n * sizeof(int));

   printf("Enter the elements:\n");
   for(int i = 0; i < n; i++)
   {
      for(int j = 0; j < n; j++)
      {
         scanf("%d", &mat[i][j]);
      }
   }
#pragma omp parallel for reduction(+:count)
   for(int i = 0; i < n; i++)
   {
      for(int j = 0; j < n; j++)
      {
         int isMin = 1, isMax = 1;
         for(int k = 0; k < n; k++)
         {
            if(mat[i][k] < mat[i][j])
               isMin = 0;
         }
         for(int k = 0; k < n; k++)
         {
            if(mat[k][j] > mat[i][j])
               isMax = 0;
         }
         if(isMin && isMax)
            count++;
      }
   }
   printf("The count of saddle points: %d\n", count);
   return 0;
}

