#include<stdio.h>
#include<stdlib.h>
#include<mpi.h>
#include<time.h>
int main()
{
	int rank,size,key,N;
	int local_count=0,total_count=0;
	int *array;
	int *sub_array;
	MPI_Init(NULL,NULL);
	MPI_Comm_rank(MPI_COMM_WORLD,&rank);
	MPI_Comm_size(MPI_COMM_WORLD,&size);
	//int elements_per_process=N/size;
	//sub_array=(int*)malloc(elements_per_process*sizeof(int));
	if(rank==0)
	{
                printf("Enter no. of array elements:");
                fflush(stdout);
                scanf("%d",&N);
                if(N%size !=0){printf("\nTotal elements must be divisible by no. of processes"); fflush(stdout); MPI_Abort(MPI_COMM_WORLD,1);}
		array=(int*)malloc(N*sizeof(int));
		srand(time(NULL));
		for(int i=0;i<N;i++)
		{
			array[i]=rand()%10;
			printf("%d ",array[i]);
		}
		printf("\nEnter a number to find the frequency:");
		fflush(stdout);
		scanf("%d",&key);
	}
	MPI_Bcast(&N,1,MPI_INT,0,MPI_COMM_WORLD);
        int elements_per_process=N/size;
        sub_array=(int*)malloc(elements_per_process*sizeof(int));
	MPI_Bcast(&key,1,MPI_INT,0,MPI_COMM_WORLD);
	MPI_Scatter(array,elements_per_process,MPI_INT,sub_array,elements_per_process,MPI_INT,0,MPI_COMM_WORLD);
	for(int i=0;i<elements_per_process;i++)
	{
		if(sub_array[i]==key)
			local_count++;
	}
	printf("Process %d found %d %d times\n",rank,key,local_count);
	MPI_Reduce(&local_count,&total_count,1,MPI_INT,MPI_SUM,0,MPI_COMM_WORLD);
	if(rank==0)
	{
		printf("Total Frequency of key %d is %d\n",key,total_count);
		free(array);
	}
	free(sub_array);
	MPI_Finalize();
	return 0;
}
